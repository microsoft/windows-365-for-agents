{
  // ──────────────────────────────────────────────────────────────────────────
  // AgentApplication: M365 Agents SDK options (auth handlers, middleware).
  // The auth handler named here ("agentic") must also appear under
  // UserAuthorization.Handlers below.
  // ──────────────────────────────────────────────────────────────────────────
  "AgentApplication": {
    "StartTypingTimer": false,
    "RemoveRecipientMention": false,
    "NormalizeMentions": false,
    "AgenticAuthHandlerName": "agentic",
    "UserAuthorization": {
      "AutoSignin": false,
      "Handlers": {
        "agentic": {
          "Type": "AgenticUserAuthorization",
          "Settings": {
            "Scopes": [
              "https://graph.microsoft.com/.default"
            ],
            // Falls back to this connection (defined below) when token acquisition needs it.
            "AlternateBlueprintConnectionName": "ServiceConnection"
          }
        }
      }
    }
  },

  // ──────────────────────────────────────────────────────────────────────────
  // TokenValidation: validates incoming JWT (Bot Framework or A365 agentic tokens).
  // Disable in dev (Enabled: false) and rely on BEARER_TOKEN env var if needed.
  // In production, set Enabled: true and provide the Azure Bot Client ID as Audience.
  // ──────────────────────────────────────────────────────────────────────────
  "TokenValidation": {
    "Audiences": [
      "<<agentBlueprintId>>"
    ],
    "Enabled": false,
    "TenantId": "<<tenantId>>"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Agents": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.SemanticKernel*": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ──────────────────────────────────────────────────────────────────────────
  // Connections: how the agent acquires tokens to call other services.
  // For production, AuthType "UserManagedIdentity" is recommended (uses the
  // Web App's managed identity + Federated Identity Credential). For local dev,
  // override `ClientId` / `ClientSecret` via `dotnet user-secrets`.
  // ──────────────────────────────────────────────────────────────────────────
  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/<<tenantId>>",
        "ClientId": "<<agentBlueprintId>>",
        "Scopes": [
          // A365 Tools service principal — required scope for invoking MCP tools via the
          // platform. This is a public Microsoft-owned app ID; do not change.
          "5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default"
        ],
        "ClientSecret": "<<Connections__ServiceConnection__Settings__ClientSecret>>",
        "AgentId": "<<agentBlueprintId>>"
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],

  // ──────────────────────────────────────────────────────────────────────────
  // AzureOpenAI: where the LLM lives. The model deployment must support the
  // OpenAI Responses API. Use dotnet user-secrets locally; use Azure App
  // Settings (env vars with __ separator) in production.
  // ──────────────────────────────────────────────────────────────────────────
  "AIServices": {
    "AzureOpenAI": {
      "DeploymentName": "<<AIServices__AzureOpenAI__DeploymentName>>",
      "Endpoint": "<<AIServices__AzureOpenAI__Endpoint>>",
      "ApiVersion": "<<AIServices__AzureOpenAI__ApiVersion>>",
      "ApiKey": "<<AIServices__AzureOpenAI__ApiKey>>"
    }
  }
}
